{
  "name": "charbi-font",
  "version": "0.3.2",
  "description": "中文字体子集化工具，扫描代码提取字符，生成精简字体包",
  "keywords": [
    "builder",
    "cli",
    "font",
    "subset"
  ],
  "homepage": "https://github.com/imba97/charbi-font#readme",
  "license": "MIT",
  "author": "imba97",
  "repository": {
    "type": "git",
    "url": "git@github.com:imba97/charbi-font.git"
  },
  "bin": {
    "charbi": "./bin/charbi.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "typesVersions": {
    "*": {
      "loader": [
        "./dist/config/loader.d.mts"
      ],
      "config": [
        "./dist/config/index.d.mts"
      ],
      "vite": [
        "./dist/vite/index.d.mts"
      ],
      "client": [
        "./dist/client.d.mts"
      ]
    }
  },
  "exports": {
    "./cli": {
      "import": "./dist/cli.mjs",
      "require": "./dist/cli.cjs"
    },
    "./client": {
      "import": "./dist/client.mjs",
      "require": "./dist/client.cjs"
    },
    "./config": {
      "import": "./dist/config/index.mjs",
      "require": "./dist/config/index.cjs"
    },
    "./config/loader": {
      "import": "./dist/config/loader.mjs",
      "require": "./dist/config/loader.cjs"
    },
    "./vite": {
      "import": "./dist/vite/index.mjs",
      "require": "./dist/vite/index.cjs"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "charbi": "node dist/cli.mjs",
    "test": "vp test run",
    "test:watch": "vp test",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "fmt": "vp fmt",
    "fmt:fix": "vp fmt --write",
    "prepare": "simple-git-hooks",
    "release": "bumpp"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "consola": "^3.4.2",
    "defu": "^6.1.7",
    "enquirer": "^2.4.1",
    "fast-glob": "^3.3.3",
    "fontmin": "^1.1.1",
    "p-limit": "^7.3.0",
    "unconfig": "^7.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "bumpp": "^11.0.1",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "nano-staged": "^1.0.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.16"
  },
  "peerDependencies": {
    "cos-nodejs-sdk-v5": "*"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "src/**/*.{ts,js,mjs,cjs}": "vp check --fix",
    "vite.config.ts": "vp check --fix",
    "package.json": "vp check --fix",
    "README.md": "vp check --fix"
  },
  "packageManager": "pnpm@10.33.0"
}
